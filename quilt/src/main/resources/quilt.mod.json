{
  "schema_version": 1,
  "quilt_loader": {
    "group": "bookercatch.smoothmenu",
    "id": "${mod_id}",
    "version": "${version}",
    "metadata": {
      "name": "${mod_name}",
      "description": "${mod_description}",
      "license": "MIT",
      "contributors": {
        "noramibu": "Developer",
        "BookerCatch": "Developer"
      },
      "contact": {
        "sources": "https://github.com/noramibu/SmoothMenuReloaded"
      }
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "depends": [
      {
        "id": "quilt_loader",
        "versions": ">=${quilt_loader}"
      },
      {
        "id": "minecraft",
        "versions": "~${minecraft_version}"
      },
      {
        "id": "java",
        "versions": ">=25"
      }
    ]
  },
  "mixin": [
    "smoothmenu.quilt.mixins.json"
  ]
}

